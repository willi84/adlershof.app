---
title: "Ordnungsamt Dashboard"
layout: base.njk
---

{% set dataset = ordnungsamt.dataset %}

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
>

<div class="container dashboard" data-ordnungsamt-dashboard>
  <div class="container my-5">
    <h1 class="title">Adlershof<span>.issues</span></h1>
    <p class="small center">🧭 Ordnungsamt-Meldungen mit Zeitfilter, Hotspots und Dauer-Metriken</p>
    <p class="center">
      Quelle: <strong>{{ dataset.source.modeLabel }}</strong>
      {% if dataset.source.scopeLabel %}
        · {{ dataset.source.scopeLabel }}
      {% endif %}
    </p>
    <p class="center small">
      Datenquelle:
      <a href="/data/ordnungsamt.json" target="_blank">/data/ordnungsamt.json</a>
      · Generierung: <strong>{{ dataset.generationDurationText }}</strong>
      {% if dataset.source.dumpPath %}
        · Dump: <code>{{ dataset.source.dumpPath }}</code>
      {% endif %}
    </p>
  </div>

  <section class="dashboard__stats" data-widget="stats">
    <div class="dashboard__widget-toggle-wrap"><button type="button" class="dashboard__widget-toggle" data-action="toggle-widget" data-target="stats" aria-expanded="true">Einklappen</button></div>
    <div class="dashboard__widget-body">
    <article class="dashboard__card dashboard__card--accent">
      <span class="dashboard__label">📌 Gefilterte Meldungen</span>
      <strong class="dashboard__value" id="issue-count">{{ dataset.totals.adlershof }}</strong>
    </article>
    <article class="dashboard__card">
      <span class="dashboard__label">🌍 Quelle gesamt</span>
      <strong class="dashboard__value" id="source-total-count">{{ dataset.totals.source }}</strong>
    </article>
    <article class="dashboard__card">
      <span class="dashboard__label">🧹 Vorfilter Treptow/Adlershof</span>
      <strong class="dashboard__value" id="candidate-total-count">{{ dataset.totals.districtCandidates }}</strong>
    </article>
    <article class="dashboard__card">
      <span class="dashboard__label">⏱️ JSON-Generierung</span>
      <strong class="dashboard__value dashboard__value--small" id="generation-duration">{{ dataset.generationDurationText }}</strong>
    </article>
      </div>
  </section>

  <section class="dashboard__grid dashboard__grid--filters" data-widget="filters-map">
    <div class="dashboard__widget-toggle-wrap"><button type="button" class="dashboard__widget-toggle" data-action="toggle-widget" data-target="filters-map" aria-expanded="true">Einklappen</button></div>
    <div class="dashboard__widget-body">
    <article class="dashboard__panel dashboard__panel--soft">
      <h2>🎛️ Filter</h2>
      <div class="dashboard__filters">
        <label class="dashboard__field">
          <span>Jahr</span>
          <select class="form-control dashboard__select" id="issue-year"></select>
        </label>
        <label class="dashboard__field">
          <span>Monat</span>
          <select class="form-control dashboard__select" id="issue-month"></select>
        </label>
        <label class="dashboard__field">
          <span>Status</span>
          <select class="form-control dashboard__select" id="issue-status"></select>
        </label>
        <label class="dashboard__field dashboard__field--wide">
          <span>Suche</span>
          <input
            type="text"
            class="form-control"
            id="issue-search"
            placeholder="Suche nach Betreff, Straße, Beschreibung oder Status"
            onkeyup="searchIssues()"
          >
        </label>
      </div>
      <div id="issue-no-result" class="form-text search__no-result hidden">
        Keine Treffer für <span class="search__value"></span>
      </div>
      <p class="small" id="issue-summary-text">
        <span id="issue-visible-count">{{ dataset.issues | length }}</span>
        von {{ dataset.issues | length }} Meldungen sichtbar
      </p>
    </article>

    <article class="dashboard__panel dashboard__panel--map">
      <h2>🗺️ Hotspots</h2>
      <div id="issues-map" class="dashboard__map"></div>
      <p class="small dashboard__map-hint">Gewichtete Flächen basieren auf gruppierten Hotspots der aktuell gefilterten Meldungen.</p>
      <div id="hotspot-legend" class="hotspot-legend"></div>
    </article>
    </div>
  </section>

  <section class="dashboard__grid" data-widget="analytics">
    <div class="dashboard__widget-toggle-wrap"><button type="button" class="dashboard__widget-toggle" data-action="toggle-widget" data-target="analytics" aria-expanded="true">Einklappen</button></div>
    <div class="dashboard__widget-body">
    <article class="dashboard__panel dashboard__panel--wide">
      <div class="dashboard__panel-headline">
        <h2>🟩 Aktivität</h2>
              </div>
      <div id="activity-heatmap" class="activity-heatmap"></div>
    </article>

    <article class="dashboard__panel">
      <h2>🧱 Häufigste Issue-Typen</h2>
      <ul class="dashboard__ranking" id="ranking-issue-types"></ul>
    </article>

    <article class="dashboard__panel">
      <h2>🛣️ Häufigste Straßen</h2>
      <ul class="dashboard__ranking" id="ranking-streets"></ul>
    </article>

    <article class="dashboard__panel">
      <h2>📍 Häufigste Adressen</h2>
      <ul class="dashboard__ranking" id="ranking-addresses"></ul>
    </article>

    <article class="dashboard__panel">
      <h2>🔥 Hotspots</h2>
      <ul class="dashboard__ranking" id="ranking-hotspots"></ul>
    </article>

    <article class="dashboard__panel">
      <h2>🚦 Status</h2>
      <ul class="dashboard__ranking" id="ranking-status"></ul>
    </article>
    </div>
  </section>

  <section class="dashboard__panel dashboard__panel--wide" data-widget="today">
    <div class="dashboard__panel-headline">
      <h2>📅 Heute</h2>
      <p class="small">Alle heutigen Meldungen inkl. Bild, falls in den Detaildaten vorhanden.</p>
    </div>
    <div class="dashboard__widget-toggle-wrap"><button type="button" class="dashboard__widget-toggle" data-action="toggle-widget" data-target="today" aria-expanded="true">Einklappen</button></div>
    <div class="dashboard__widget-body">
      <ul class="items items--dashboard" id="today-issues-list"></ul>
    </div>
  </section>

  <section class="dashboard__panel dashboard__panel--wide" data-widget="issues">
    <div class="dashboard__panel-headline">
      <h2>🗂️ Alle Meldungen</h2>
      <p class="small">PLZ und Bezirk sind in den Zusatzdetails einklappbar.</p>
    </div>
    <div class="issues-toolbar">
      <div id="issue-status-buttons" class="issues-toolbar__buttons"></div>
      <label class="dashboard__field issues-toolbar__field">
        <span>Dienstleister</span>
        <select class="form-control dashboard__select" id="issue-provider"></select>
      </label>
    </div>
    <div class="dashboard__widget-toggle-wrap"><button type="button" class="dashboard__widget-toggle" data-action="toggle-widget" data-target="issues" aria-expanded="true">Einklappen</button></div>
    <div class="dashboard__widget-body">
      <ul class="items items--dashboard" id="issues-list"></ul>
    </div>
  </section>
</div>

<script id="ordnungsamt-data" type="application/json">{{ dataset | dump | safe }}</script>
<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
></script>
